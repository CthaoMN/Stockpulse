{
  "manifest_version": 3,
  "name": "StockPulse Cookie Sync",
  "version": "1.1",
  "description": "Auto-syncs Target.com cookies and monitors Discord for stock alerts",
  "permissions": [
    "cookies",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.target.com/*",
    "http://*.target.com/*",
    "http://localhost:3069/*",
    "https://discord.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/channels/*"],
      "js": ["discord-watcher.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["https://discord.com/*"]
  },
  "action": {
    "default_popup": "popup.html"
  }
}
